<script type="x-shader/x-vertex" id="saturnVertexShader">
attribute float size;
attribute vec3 customColor;
attribute float opacityAttr;
attribute float orbitSpeed;
attribute float isRing;
attribute float aRandomId;
attribute float phase;
attribute float brightness;

varying vec3 vColor;
varying float vOpacity;
varying float vIsRing;
varying float vBrightness;
varying float vRim;
varying float vDepthFade;
varying float vTwinkle;

uniform float uTime;
uniform float uScale;
uniform float uRotationX;
uniform float uChaos;

mat2 rotate2d(float a) { return mat2(cos(a), -sin(a), sin(a), cos(a)); }

void main() {
    vec3 pos = position;

    if (isRing > 0.5) {
        float angleOffset = uTime * orbitSpeed * 0.045;
        vec2 rotatedXZ = rotate2d(angleOffset) * pos.xz;
        pos.x = rotatedXZ.x;
        pos.z = rotatedXZ.y;
    } else {
        float bodyAngle = uTime * 0.035;
        vec2 rotatedXZ = rotate2d(bodyAngle) * pos.xz;
        pos.x = rotatedXZ.x;
        pos.z = rotatedXZ.y;
    }

    if (uChaos > 0.001) {
        vec3 burstDir = normalize(pos + vec3(sin(aRandomId * 12.0), cos(aRandomId * 12.0), 0.0));
        burstDir.z += aRandomId * 1.4;
        pos += burstDir * pow(uChaos, 1.4) * (isRing > 0.5 ? 20.0 : 12.0) * (0.25 + aRandomId * 0.75);
    }

    float cx = cos(uRotationX);
    float sx = sin(uRotationX);
    float ry = pos.y * cx - pos.z * sx;
    float rz = pos.y * sx + pos.z * cx;
    pos.y = ry;
    pos.z = rz;

    vec4 mvPosition = modelViewMatrix * vec4(pos * uScale, 1.0);
    float dist = -mvPosition.z;
    gl_Position = projectionMatrix * mvPosition;

    float sizeScale = isRing > 0.5 ? 0.58 : 0.70;
    float pointSize = size * (410.0 / dist) * sizeScale;
    pointSize *= mix(1.0, 0.85, uChaos);
    float maxSize = isRing > 0.5 ? 2.35 : 2.75;
    gl_PointSize = clamp(pointSize, 0.0, maxSize + 1.2 * uScale);

    vColor = customColor;
    vOpacity = opacityAttr;
    vIsRing = isRing;
    vBrightness = brightness;
    vDepthFade = smoothstep(240.0, 40.0, dist);

    vec3 n = normalize(position);
    vRim = pow(1.0 - abs(n.z), isRing > 0.5 ? 1.9 : 2.4);

    float twinkleBase = isRing > 0.5 ? 0.96 : 0.985;
    float twinkleAmp  = isRing > 0.5 ? 0.04 : 0.015;
    vTwinkle = twinkleBase + twinkleAmp * sin(uTime * (isRing > 0.5 ? 0.8 : 0.45) + phase);
}
</script>

<script type="x-shader/x-fragment" id="saturnFragmentShader">
varying vec3 vColor;
varying float vOpacity;
varying float vIsRing;
varying float vBrightness;
varying float vRim;
varying float vDepthFade;
varying float vTwinkle;

void main() {
    vec2 c = 2.0 * gl_PointCoord - 1.0;
    float r2 = dot(c, c);
    if (r2 > 1.0) discard;

    float soft = exp(-r2 * (vIsRing > 0.5 ? 2.5 : 2.2));
    float core = exp(-r2 * (vIsRing > 0.5 ? 5.8 : 4.9));

    float alpha = soft * vOpacity * vDepthFade;
    vec3 color = vColor * (0.62 + 0.48 * vBrightness) * vTwinkle;
    color += vColor * core * (vIsRing > 0.5 ? 0.10 : 0.14);
    color += vec3(1.0, 0.95, 0.82) * vRim * (vIsRing > 0.5 ? 0.10 : 0.16) * vBrightness;

    gl_FragColor = vec4(color, alpha);
}
</script>

<script type="x-shader/x-vertex" id="starVertexShader">
attribute float size;
attribute vec3 customColor;
attribute float aRandomId;
attribute float depthFactor;
varying vec3 vColor;
varying float vAlpha;
uniform float uTime;
uniform float uChaos;
uniform float uFieldRotation;
void main() {
    vec3 pos = position;

    // 仿照参考图：整体以稳定天穹为主，只给极弱的旋转联动和近远层差
    float skyRot = uFieldRotation * (0.010 + 0.010 * depthFactor) + uTime * (0.00045 + 0.00025 * depthFactor);
    float ca = cos(skyRot);
    float sa = sin(skyRot);
    pos.xz = mat2(ca, -sa, sa, ca) * pos.xz;

    // 极弱互动：近层星点有非常轻的视差，不做漂浮感
    pos.x += sin(uTime * 0.010 + aRandomId * 9.0) * (0.045 * depthFactor);
    pos.y += cos(uTime * 0.008 + aRandomId * 11.0) * (0.035 * depthFactor);

    // 失控态也只做轻微深度扰动，避免背景炸开
    if (uChaos > 0.01) {
        pos.z += uChaos * aRandomId * (18.0 + 55.0 * depthFactor);
    }

    vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
    gl_PointSize = clamp(size * (1380.0 / -mvPosition.z), 0.0, 8.8);
    gl_Position = projectionMatrix * mvPosition;
    vColor = customColor;
    vAlpha = (1.02 + 0.28 * sin(uTime * 0.06 + aRandomId * 15.0)) * (1.05 + 0.30 * depthFactor);
}
</script>

<script type="x-shader/x-fragment" id="starFragmentShader">
varying vec3 vColor;
varying float vAlpha;
void main() {
    vec2 c = 2.0 * gl_PointCoord - 1.0;
    float r2 = dot(c, c);
    if (r2 > 1.0) discard;

    float core = exp(-r2 * 18.0);
    float halo = exp(-r2 * 2.2);
    float alpha = (0.82 * halo + 1.18 * core) * vAlpha * 1.28;
    vec3 color = vColor * (1.08 * halo + 1.34 * core);

    gl_FragColor = vec4(color, alpha);
}
</script>

<script>
let scene, camera, renderer, saturnPoints, starField;
let uniforms, starUniforms;
let targetScale = 1.0, currentScale = 1.0;
let targetRotX = 0.42, currentRotX = 0.42;
let targetRotY = 0.0, currentRotY = 0.0;
let targetChaos = 0.0, currentChaos = 0.0;
let isHandDetected = false;
let lastInteractionTime = Date.now();
const statusMode = document.getElementById('status-mode');
const signalSrc = document.getElementById('signal-src');
const loadingEl = document.getElementById('loading');
let smoothDist = 0, smoothCx = 0, smoothCy = 0;
let isFirstFrame = true;
let lastHandSeenTime = 0;
const HAND_LOST_HOLD_MS = 260;

// 手势识别稳定化与方向精度优化：只增强识别，不改视觉结构
const DIST_NOISE_GATE_BASE = 0.0048;
const POS_NOISE_GATE_X = 0.0032;
const POS_NOISE_GATE_Y = 0.0038;
const SUPERNOVA_THRESHOLD = 0.46;
const DIST_SMOOTH_ALPHA = 0.13;
const MAX_DIST_STEP = 0.018;
const MAX_POS_STEP_X = 0.014;
const MAX_POS_STEP_Y = 0.012;
const AXIS_ALPHA_BASE_X = 0.12;
const AXIS_ALPHA_FAST_X = 0.24;
const AXIS_ALPHA_BASE_Y = 0.10;
const AXIS_ALPHA_FAST_Y = 0.20;
const AXIS_RESPONSE_GAMMA_X = 0.92;
const AXIS_RESPONSE_GAMMA_Y = 0.98;
const AXIS_DEADZONE_X = 0.022;
const AXIS_DEADZONE_Y = 0.024;

function toggleSidebar() {
    const panel = document.getElementById('sidebar-panel');
    panel.classList.toggle('panel-collapsed');
}

function lerp(a, b, t) { return a + (b - a) * t; }

function clamp(v, min, max) { return Math.max(min, Math.min(max, v)); }

function smoothAxis(current, raw, gate, alphaBase, alphaFast, maxStep) {
    const delta = raw - current;
    const ad = Math.abs(delta);
    if (ad <= gate) return current;
    const t = clamp((ad - gate) / 0.08, 0.0, 1.0);
    const alpha = lerp(alphaBase, alphaFast, t);
    const step = clamp(delta * alpha, -maxStep, maxStep);
    return current + step;
}

function remapAxis(centered, deadzone, gamma) {
    const sign = centered < 0 ? -1.0 : 1.0;
    const mag = Math.abs(centered);
    if (mag <= deadzone) return 0.0;
    const norm = clamp((mag - deadzone) / (0.5 - deadzone), 0.0, 1.0);
    return sign * Math.pow(norm, gamma);
}

function buildSaturnGeometry() {
    const bodyCount = 420000;
    const ringCount = 580000;
    const totalCount = bodyCount + ringCount;
    const geo = new THREE.BufferGeometry();

    const pos = new Float32Array(totalCount * 3);
    const cols = new Float32Array(totalCount * 3);
    const sizes = new Float32Array(totalCount);
    const ringAttr = new Float32Array(totalCount);
    const randomIds = new Float32Array(totalCount);
    const speeds = new Float32Array(totalCount);
    const ops = new Float32Array(totalCount);
    const phases = new Float32Array(totalCount);
    const bright = new Float32Array(totalCount);

    const a = 18.2;
    const c = 15.0;
    const light = new THREE.Vector3(-0.45, 0.28, 0.86).normalize();

    function setPoint(i, x, y, z, r, g, b, size, isRing, orbitSpeed, opacity, brightness) {
        pos[i*3] = x; pos[i*3+1] = y; pos[i*3+2] = z;
        cols[i*3] = r; cols[i*3+1] = g; cols[i*3+2] = b;
        sizes[i] = size;
        ringAttr[i] = isRing ? 1 : 0;
        randomIds[i] = Math.random();
        speeds[i] = orbitSpeed;
        ops[i] = opacity;
        phases[i] = Math.random() * Math.PI * 2;
        bright[i] = brightness;
    }

    for (let i = 0; i < bodyCount; i++) {
        const u = Math.random();
        const v = Math.random();
        const theta = 2.0 * Math.PI * u;
        const mu = 2.0 * v - 1.0;
        const phi = Math.asin(mu);

        const cp = Math.cos(phi), sp = Math.sin(phi);
        const ct = Math.cos(theta), st = Math.sin(theta);

        let x = a * cp * ct;
        let y = c * sp;
        let z = a * cp * st;

        // 大气薄层扰动
        const shell = 0.94 + Math.random() * 0.07;
        x *= shell; y *= shell; z *= shell;

        const nx = x / (a * a);
        const ny = y / (c * c);
        const nz = z / (a * a);
        const nl = Math.max(0.0, (nx * light.x + ny * light.y + nz * light.z) / Math.sqrt(nx*nx + ny*ny + nz*nz));

        const lat = Math.abs(y / c);
        const belt1 = 0.5 + 0.5 * Math.sin(phi * 8.5 + 0.7);
        const belt2 = 0.5 + 0.5 * Math.sin(phi * 15.0 - 0.9);
        const belt3 = 0.5 + 0.5 * Math.sin(phi * 25.0 + 1.6);
        const stormNoise = 0.05 * Math.sin(theta * 7.0 + phi * 9.0) + 0.025 * Math.sin(theta * 13.0 - phi * 15.0);
        const ringShadow = Math.exp(-Math.pow(y / 1.85, 2.0)) * (z > 0.0 ? 0.34 : 0.10);
        const polarCool = Math.pow(lat, 1.55) * 0.22;
        const polarHood = Math.pow(Math.max(0.0, lat - 0.72) / 0.28, 1.45);
        const equatorHaze = Math.exp(-Math.pow(y / 3.7, 2.0)) * 0.075;
        const bandMix = 0.42 * belt1 + 0.33 * belt2 + 0.25 * belt3;
        const zoneContrast = 0.5 + 0.5 * Math.sin(phi * 5.4 - 0.4);
        const terminatorSoft = Math.pow(1.0 - nl, 1.7) * 0.06;

        let r = 0.73 + bandMix * 0.19 + zoneContrast * 0.04 + nl * 0.16 - polarCool * 0.11 - ringShadow + stormNoise - terminatorSoft;
        let g = 0.63 + bandMix * 0.16 + zoneContrast * 0.03 + nl * 0.125 - polarCool * 0.08 - ringShadow * 0.95 + stormNoise * 0.7 - terminatorSoft * 0.9;
        let b = 0.44 + bandMix * 0.10 + zoneContrast * 0.015 + nl * 0.07 - polarCool * 0.055 - ringShadow * 0.80 + stormNoise * 0.32 - terminatorSoft * 0.8;

        // 加强“更像土星”的几个元素：赤道朦胧暖带、极区冷暗帽、环影更明确
        r += equatorHaze + polarHood * 0.015;
        g += equatorHaze * 0.82 + polarHood * 0.008;
        b += equatorHaze * 0.24 - polarHood * 0.030;

        r = Math.min(1.0, Math.max(0.08, r));
        g = Math.min(1.0, Math.max(0.08, g));
        b = Math.min(1.0, Math.max(0.08, b));

        const opacity = 0.62 + nl * 0.28;
        const size = 0.56 + Math.random() * 0.34;
        const brightness = 0.35 + nl * 0.95 + (1.0 - lat) * 0.10;
        setPoint(i, x, y, z, r, g, b, size, false, 0.0, opacity, brightness);
    }

    const ringBands = [
        // 进一步强化内环：继续把粒子预算和可见度集中到近内环，外环基本维持原状
        { min: 20.8, max: 23.2, weight: 0.23, color: [0.64, 0.59, 0.52], alpha: 0.36 },
        { min: 23.6, max: 30.4, weight: 0.60, color: [1.00, 0.91, 0.76], alpha: 0.68 },
        { min: 30.9, max: 32.2, weight: 0.04, color: [0.18, 0.17, 0.16], alpha: 0.04 }, // 卡西尼缝
        { min: 32.4, max: 39.0, weight: 0.11, color: [0.76, 0.69, 0.59], alpha: 0.19 },
        { min: 39.4, max: 46.0, weight: 0.02, color: [0.40, 0.37, 0.33], alpha: 0.10 }
    ];
    const weights = ringBands.map(b => b.weight);
    const totalWeight = weights.reduce((s, x) => s + x, 0);

    function sampleBand() {
        let r = Math.random() * totalWeight;
        for (const band of ringBands) {
            r -= band.weight;
            if (r <= 0) return band;
        }
        return ringBands[ringBands.length - 1];
    }

    for (let j = 0; j < ringCount; j++) {
        const i = bodyCount + j;
        const band = sampleBand();

        // 更接近真实的表面密度：按面积均匀
        const rr = Math.sqrt(THREE.MathUtils.lerp(band.min * band.min, band.max * band.max, Math.random()));
        const ang = Math.random() * Math.PI * 2.0;
        const thickness = 0.06 + (rr - 20.8) / 50.0 * 0.18;
        const x = Math.cos(ang) * rr;
        const z = Math.sin(ang) * rr;
        let y = (Math.random() - 0.5) * thickness;

        const radial = (rr - band.min) / (band.max - band.min + 1e-5);
        const densityEdge = Math.sin(Math.PI * Math.min(1.0, Math.max(0.0, radial)));
        const azimuthMod = 0.96 + 0.04 * Math.sin(ang * 14.0 + rr * 0.6);
        const frontBack = z > 0 ? 0.93 : 0.72; // 后环更暗
        const shadowZone = Math.exp(-Math.pow((Math.abs(x) - 17.0) / 7.0, 2.0)) * Math.exp(-Math.pow(y / 0.4, 2.0)) * (z > 0 ? 0.18 : 0.05);

        let r = band.color[0] * (0.82 + densityEdge * 0.35) * azimuthMod - shadowZone;
        let g = band.color[1] * (0.82 + densityEdge * 0.33) * azimuthMod - shadowZone * 0.95;
        let b = band.color[2] * (0.84 + densityEdge * 0.30) * azimuthMod - shadowZone * 0.90;

        r *= frontBack; g *= frontBack; b *= frontBack;
        r = Math.min(1.0, Math.max(0.02, r));
        g = Math.min(1.0, Math.max(0.02, g));
        b = Math.min(1.0, Math.max(0.02, b));

        const orbitSpeed = 16.0 / Math.pow(rr, 1.5); // 开普勒近似
        const opacity = band.alpha * (0.45 + densityEdge * 0.75) * frontBack;
        const size = 0.28 + Math.random() * 0.22 + densityEdge * 0.08;
        const brightness = 0.32 + densityEdge * 0.68;
        setPoint(i, x, y, z, r, g, b, size, true, orbitSpeed, opacity, brightness);
    }

    geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
    geo.setAttribute('customColor', new THREE.BufferAttribute(cols, 3));
    geo.setAttribute('size', new THREE.BufferAttribute(sizes, 1));
    geo.setAttribute('isRing', new THREE.BufferAttribute(ringAttr, 1));
    geo.setAttribute('orbitSpeed', new THREE.BufferAttribute(speeds, 1));
    geo.setAttribute('opacityAttr', new THREE.BufferAttribute(ops, 1));
    geo.setAttribute('aRandomId', new THREE.BufferAttribute(randomIds, 1));
    geo.setAttribute('phase', new THREE.BufferAttribute(phases, 1));
    geo.setAttribute('brightness', new THREE.BufferAttribute(bright, 1));
    return geo;
}

function initSaturn() {
    const geo = buildSaturnGeometry();

    uniforms = {
        uTime: { value: 0 },
        uScale: { value: 1 },
        uRotationX: { value: 0.42 },
        uChaos: { value: 0.0 }
    };

    saturnPoints = new THREE.Points(geo, new THREE.ShaderMaterial({
        uniforms,
        vertexShader: document.getElementById('saturnVertexShader').textContent,
        fragmentShader: document.getElementById('saturnFragmentShader').textContent,
        transparent: true,
        depthWrite: false,
        blending: THREE.NormalBlending
    }));
    saturnPoints.rotation.z = 0.34;
    scene.add(saturnPoints);
}

function initStarfield() {
    const starCount = 76000;
    const geo = new THREE.BufferGeometry();
    const pos = new Float32Array(starCount * 3);
    const cols = new Float32Array(starCount * 3);
    const sizes = new Float32Array(starCount);
    const randomIds = new Float32Array(starCount);
    const depthFactors = new Float32Array(starCount);

    // 参考图风格：主体是均匀分布的真实星空，叠加一条非常淡的斜向星带
    const bandTiltX = -0.18;
    const bandTiltZ = 0.12;
    const rotX = new THREE.Matrix4().makeRotationX(bandTiltX);
    const rotZ = new THREE.Matrix4().makeRotationZ(bandTiltZ);

    for (let i = 0; i < starCount; i++) {
        const inBand = Math.random() < 0.42;
        const depthLayer = Math.random();
        depthFactors[i] = depthLayer;

        let x, y, z;

        if (inBand) {
            // 非常淡的斜向星带，不做明显银河云雾，只增加一点星点密度
            const radius = 1200 + Math.random() * 4200;
            const angle = Math.random() * Math.PI * 2.0;
            const spreadY = (Math.random() - 0.5) * (180 + Math.random() * 300);
            x = Math.cos(angle) * radius;
            z = Math.sin(angle) * radius;
            y = spreadY;
            const v = new THREE.Vector3(x, y, z).applyMatrix4(rotX).applyMatrix4(rotZ);
            x = v.x; y = v.y; z = v.z;
        } else {
            // 主体星空：更接近参考图的均匀、深邃、遍布整个背景
            x = (Math.random() - 0.5) * 6600;
            y = (Math.random() - 0.5) * 4600;
            z = (Math.random() - 0.5) * 6600;
        }

        pos[i*3] = x;
        pos[i*3+1] = y;
        pos[i*3+2] = z;

        // 更像真实星空的恒星色温：白星为主，少量蓝白与暖黄
        const tint = Math.random();
        let r = 0.96, g = 0.97, b = 1.0;
        if (tint < 0.10) { r = 0.78; g = 0.86; b = 1.0; }
        else if (tint > 0.93) { r = 1.0; g = 0.90; b = 0.78; }
        else if (tint > 0.82) { r = 0.96; g = 0.97; b = 1.0; }

        const bandBoost = inBand ? (1.10 + Math.random() * 0.24) : (1.00 + Math.random() * 0.22);
        cols[i*3] = Math.min(1.0, r * bandBoost);
        cols[i*3+1] = Math.min(1.0, g * bandBoost);
        cols[i*3+2] = Math.min(1.0, b * bandBoost);

        // 很多细小星点 + 少量更亮的星点，接近截图里的层次
        const giant = Math.random() < 0.048;
        const medium = Math.random() < 0.24;
        if (giant) {
            sizes[i] = 3.10 + Math.random() * 1.85 + depthLayer * 0.35;
        } else if (medium) {
            sizes[i] = 1.35 + Math.random() * 1.18 + depthLayer * 0.24;
        } else {
            sizes[i] = 0.42 + Math.random() * 0.72 + depthLayer * 0.18;
        }

        randomIds[i] = Math.random();
    }

    geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
    geo.setAttribute('customColor', new THREE.BufferAttribute(cols, 3));
    geo.setAttribute('size', new THREE.BufferAttribute(sizes, 1));
    geo.setAttribute('aRandomId', new THREE.BufferAttribute(randomIds, 1));
    geo.setAttribute('depthFactor', new THREE.BufferAttribute(depthFactors, 1));

    starUniforms = {
        uTime: uniforms.uTime,
        uChaos: uniforms.uChaos,
        uFieldRotation: { value: 0 }
    };

    starField = new THREE.Points(geo, new THREE.ShaderMaterial({
        uniforms: starUniforms,
        vertexShader: document.getElementById('starVertexShader').textContent,
        fragmentShader: document.getElementById('starFragmentShader').textContent,
        transparent: true,
        depthWrite: false,
        blending: THREE.NormalBlending
    }));
    scene.add(starField);
}

function initThree() {
    const container = document.getElementById('canvas-container');
    scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x05070c, 0.00042);
    camera = new THREE.PerspectiveCamera(58, window.innerWidth / window.innerHeight, 1, 10000);
    camera.position.z = 106;
    initSaturn();
    initStarfield();

    renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true, powerPreference: "high-performance" });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.45));
    container.appendChild(renderer.domElement);

    setupInteractions(container);

    window.addEventListener('resize', () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
    });

    animate();
}

function setupInteractions(container) {
    let isDragging = false;
    let lastX, lastY;
    let initialPinchDist = null;

    const onStart = (x, y) => {
        isDragging = true;
        lastX = x;
        lastY = y;
        lastInteractionTime = Date.now();
        targetChaos = 0.0;
    };
    const onMove = (x, y) => {
        if (!isDragging) return;
        const dx = x - lastX;
        const dy = y - lastY;
        targetRotY += dx * 0.005;
        targetRotX += dy * 0.005;
        targetRotX = Math.max(-1.25, Math.min(1.25, targetRotX));
        lastX = x;
        lastY = y;
        lastInteractionTime = Date.now();
    };

    container.addEventListener('mousedown', e => onStart(e.clientX, e.clientY));
    window.addEventListener('mousemove', e => onMove(e.clientX, e.clientY));
    window.addEventListener('mouseup', () => isDragging = false);

    container.addEventListener('wheel', e => {
        targetScale -= e.deltaY * 0.001;
        targetScale = Math.max(0.18, Math.min(2.6, targetScale));
        lastInteractionTime = Date.now();
    }, { passive: true });

    container.addEventListener('touchstart', e => {
        lastInteractionTime = Date.now();
        targetChaos = 0.0;
        if (e.touches.length === 1) {
            onStart(e.touches[0].clientX, e.touches[0].clientY);
        } else if (e.touches.length === 2) {
            initialPinchDist = Math.hypot(
                e.touches[0].pageX - e.touches[1].pageX,
                e.touches[0].pageY - e.touches[1].pageY
            );
        }
    }, { passive: false });

    container.addEventListener('touchmove', e => {
        if (e.touches.length === 1) {
            onMove(e.touches[0].clientX, e.touches[0].clientY);
        } else if (e.touches.length === 2 && initialPinchDist) {
            const dist = Math.hypot(
                e.touches[0].pageX - e.touches[1].pageX,
                e.touches[0].pageY - e.touches[1].pageY
            );
            const zoom = dist / initialPinchDist;
            targetScale = Math.max(0.18, Math.min(2.6, targetScale * zoom));
            initialPinchDist = dist;
            lastInteractionTime = Date.now();
        }
    }, { passive: false });

    container.addEventListener('touchend', () => {
        isDragging = false;
        initialPinchDist = null;
    });
}

function animate() {
    requestAnimationFrame(animate);
    const time = performance.now() * 0.001;
    uniforms.uTime.value = time;

    const timeSinceInteract = Date.now() - lastInteractionTime;

    if (isHandDetected) {
        if (targetChaos > 0.5) {
            statusMode.innerText = "星体失控 (CHAOS)";
            statusMode.className = "state-chaos";
            signalSrc.innerText = "超新星引爆！";
            signalSrc.style.color = "#ff3333";
        } else if (currentChaos > 0.05) {
            statusMode.innerText = "引力重建 (RECOVER)";
            statusMode.className = "state-recover";
            signalSrc.innerText = "正在修复轨道...";
            signalSrc.style.color = "#33ccff";
        } else {
            statusMode.innerText = "视觉操控 (EXPAND)";
            statusMode.className = "highlight";
            signalSrc.innerText = "稳态引力场";
            signalSrc.style.color = "#0f0";
        }
    } else if (timeSinceInteract < 5000) {
        statusMode.innerText = "手动接管";
        statusMode.className = "highlight";
        signalSrc.innerText = "触控/鼠标";
        signalSrc.style.color = "#c5a059";
        targetChaos = 0.0;
    } else {
        // 待机模式保留更像“行星”的视觉姿态：
        // 回到之前更自然的环面观感，避免土星环看起来像向上翘起。
        // 去掉明显呼吸缩放，只保留极轻微稳定章动。
        targetScale = 1.0;
        targetRotX = 0.422 + Math.sin(time * 0.075) * 0.004;
        targetRotY += 0.00076;
        targetChaos = 0.0;
        statusMode.innerText = "自动巡航";
        statusMode.className = "highlight";
        signalSrc.innerText = "休眠态";
        signalSrc.style.color = "#888";
    }

    const chaosLerp = (targetChaos > currentChaos) ? 0.14 : 0.045;
    currentChaos += (targetChaos - currentChaos) * chaosLerp;
    uniforms.uChaos.value = currentChaos;

    currentScale += (targetScale - currentScale) * 0.06;
    currentRotX += (targetRotX - currentRotX) * 0.06;
    currentRotY += (targetRotY - currentRotY) * 0.06;

    uniforms.uScale.value = currentScale;
    uniforms.uRotationX.value = currentRotX;

    saturnPoints.rotation.y = currentRotY;
    starUniforms.uFieldRotation.value = currentRotY * 0.12;

    renderer.render(scene, camera);
}

const videoElement = document.getElementsByClassName('input_video')[0];
const hands = new Hands({
    locateFile: (file) => `https://cdn.jsdelivr.net/npm/@mediapipe/hands/${file}`
});
hands.setOptions({
    maxNumHands: 1,
    modelComplexity: 1,
    minDetectionConfidence: 0.5,
    minTrackingConfidence: 0.5
});

hands.onResults(results => {
    loadingEl.style.display = 'none';
    const now = performance.now();

    if (results.multiHandLandmarks && results.multiHandLandmarks.length > 0) {
        isHandDetected = true;
        lastHandSeenTime = now;
        lastInteractionTime = Date.now();

        const hand = results.multiHandLandmarks[0];
        const thumbTip = hand[4];
        const indexTip = hand[8];
        const middleTip = hand[12];

        // 用加权掌心中心提高左右/上下识别稳定性：
        // 腕点 + 掌根 + 中指掌关节权重大，边缘点只作微校正
        const wrist = hand[0];
        const indexMcp = hand[5];
        const middleMcp = hand[9];
        const ringMcp = hand[13];
        const pinkyMcp = hand[17];

        const rawCx =
            wrist.x * 0.18 +
            indexMcp.x * 0.20 +
            middleMcp.x * 0.28 +
            ringMcp.x * 0.18 +
            pinkyMcp.x * 0.16;

        const rawCy =
            wrist.y * 0.20 +
            indexMcp.y * 0.18 +
            middleMcp.y * 0.28 +
            ringMcp.y * 0.18 +
            pinkyMcp.y * 0.16;

        // 缩放距离用拇指-食指为主，辅以拇指-中指，提高张合识别稳定度
        const pinchA = Math.hypot(thumbTip.x - indexTip.x, thumbTip.y - indexTip.y);
        const pinchB = Math.hypot(thumbTip.x - middleTip.x, thumbTip.y - middleTip.y);
        const rawDist = pinchA * 0.72 + pinchB * 0.28;

        if (isFirstFrame) {
            smoothDist = rawDist;
            smoothCx = rawCx;
            smoothCy = rawCy;
            isFirstFrame = false;
        }

        let effectiveDist = rawDist;
        if (effectiveDist < 0.04) effectiveDist = 0.0;

        const dynamicDistGate = DIST_NOISE_GATE_BASE + (smoothDist * 0.018);
        const distDelta = effectiveDist - smoothDist;
        if (Math.abs(distDelta) > dynamicDistGate) {
            const step = clamp(distDelta * DIST_SMOOTH_ALPHA, -MAX_DIST_STEP, MAX_DIST_STEP);
            smoothDist += step;
        }

        smoothCx = smoothAxis(
            smoothCx,
            rawCx,
            POS_NOISE_GATE_X,
            AXIS_ALPHA_BASE_X,
            AXIS_ALPHA_FAST_X,
            MAX_POS_STEP_X
        );

        smoothCy = smoothAxis(
            smoothCy,
            rawCy,
            POS_NOISE_GATE_Y,
            AXIS_ALPHA_BASE_Y,
            AXIS_ALPHA_FAST_Y,
            MAX_POS_STEP_Y
        );

        // 即使进入失控态，也继续允许手势控制上下/左右运动；
        // 只保留“失控爆散”的视觉状态，不再锁死方向控制。
        const xNorm = remapAxis(smoothCx - 0.5, AXIS_DEADZONE_X, AXIS_RESPONSE_GAMMA_X);
        const yNorm = remapAxis(smoothCy - 0.5, AXIS_DEADZONE_Y, AXIS_RESPONSE_GAMMA_Y);

        if (smoothDist > SUPERNOVA_THRESHOLD) {
            targetChaos = 1.0;
            targetScale = 2.45;

            // 失控时降低一点灵敏度，避免爆散状态下位移/旋转显得过猛
            targetRotX = yNorm * 1.75;
            targetRotY = -xNorm * 3.1;
        } else {
            targetChaos = 0.0;
            targetScale = clamp(0.25 + smoothDist * 6.6, 0.20, 2.6);

            // 左右与上下分开做死区 + 非线性响应：
            // 小动作更稳，大动作更跟手，减少边缘区域突然抽动
            targetRotX = yNorm * 2.2;
            targetRotY = -xNorm * 4.0;
        }
    } else {
        // 给短暂丢帧一个缓冲，避免手势识别闪断造成抽动
        if (now - lastHandSeenTime > HAND_LOST_HOLD_MS) {
            isHandDetected = false;
            isFirstFrame = true;
            targetChaos = 0.0;
        }
    }
});

const cameraInst = new Camera(videoElement, {
    onFrame: async () => { await hands.send({ image: videoElement }); },
    width: 640,
    height: 480,
    facingMode: 'user'
});

cameraInst.start()
    .then(() => console.log("System Online"))
    .catch(() => {
        loadingEl.innerHTML = "手势模块加载失败<br>已切换为鼠标/触控模式";
        setTimeout(() => { loadingEl.style.display = 'none'; }, 1600);
    });

function toggleFullScreen() {
    if (!document.fullscreenElement) document.documentElement.requestFullscreen();
    else document.exitFullscreen();
}

initThree();
</script>
